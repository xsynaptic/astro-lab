{
	"name": "@xsynaptic/satteri-reading-time",
	"version": "0.2.0",
	"description": "Sätteri mdast plugin that computes multilingual reading time and injects it into Astro frontmatter.",
	"type": "module",
	"license": "MIT",
	"author": "Alexander Synaptic <x@synapticism.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xsynaptic/astro-lab.git",
		"directory": "packages/satteri-reading-time"
	},
	"homepage": "https://github.com/xsynaptic/astro-lab/tree/main/packages/satteri-reading-time#readme",
	"bugs": {
		"url": "https://github.com/xsynaptic/astro-lab/issues"
	},
	"keywords": [
		"satteri",
		"satteri-plugin",
		"mdast",
		"reading-time",
		"astro",
		"withastro"
	],
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
