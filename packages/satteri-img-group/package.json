{
	"name": "@xsynaptic/satteri-img-group",
	"version": "0.0.0",
	"description": "Sätteri plugin for MDX that handles custom image layout for Spectral Codex.",
	"type": "module",
	"license": "MIT",
	"author": "Alexander Synaptic <x@synapticism.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xsynaptic/astro-lab.git",
		"directory": "packages/satteri-img-group"
	},
	"homepage": "https://github.com/xsynaptic/astro-lab/tree/main/packages/satteri-img-group#readme",
	"bugs": {
		"url": "https://github.com/xsynaptic/astro-lab/issues"
	},
	"keywords": [
