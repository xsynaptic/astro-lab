{
	"name": "@xsynaptic/astro-image-loader",
	"version": "0.1.0",
	"description": "An Astro content layer loader that treats images as content entries, with incremental sync, caching, and pluggable metadata extraction",
	"type": "module",
	"license": "MIT",
	"author": "Alexander Synaptic <x@synapticism.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xsynaptic/astro-lab.git",
		"directory": "packages/astro-image-loader"
	},
	"homepage": "https://github.com/xsynaptic/astro-lab/tree/main/packages/astro-image-loader#readme",
	"bugs": {
		"url": "https://github.com/xsynaptic/astro-lab/issues"
	},
	"keywords": [
		"astro",
		"withastro",
		"astro-loader",
		"content-layer",
		"images",
		"sharp",
		"exif"
	],
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./exif": {
			"types": "./dist/exif.d.mts",
			"import": "./dist/exif.mjs"
		},
		"./dimensions": {
			"types": "./dist/dimensions.d.mts",
			"import": "./dist/dimensions.mjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"p-limit": "^7.3.0",
		"picomatch": "^4.0.4",
		"tinyglobby": "^0.2.15"
	},
	"peerDependencies": {
		"astro": "^6.0.0 || ^7.0.0",
		"exiftool-vendored": "^36.0.0",
		"sharp": "^0.35.2",
		"zod": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"exiftool-vendored": {
			"optional": true
		},
		"sharp": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^24.13.3",
		"@types/picomatch": "^4.0.2",
		"astro": "^7.0.7",
		"exiftool-vendored": "^36.0.0",
		"sharp": "^0.35.3",
		"zod": "^4.4.3"
	}
}
