{
	"name": "astro-lab",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "A library of plugins, utilities, and configs for use with Astro",
	"keywords": [
		"astro",
		"unified",
		"remark",
		"rehype",
		"eslint",
		"unpic"
	],
	"author": "Alexander Synaptic <x@synapticism.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xsynaptic/astro-lab.git"
	},
	"packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"prepare": "pnpm --filter './packages/*' build",
		"build": "pnpm --filter './packages/*' build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "pnpm -r --if-present test:e2e",
		"check-types": "tsc -p tsconfig.json && pnpm -r check-types",
		"lint": "eslint --max-warnings 0",
		"fix": "prettier --cache --write . && eslint --cache --cache-location node_modules/.cache/eslint/ --fix && pnpm check-types && knip",
		"check": "prettier --check . && eslint --max-warnings 0 && pnpm check-types && knip",
		"check:pkg": "pnpm --filter './packages/*' --no-bail exec publint",
		"release": "pnpm check && pnpm --filter './packages/*' build && pnpm test && pnpm test:e2e && pnpm check:pkg && changeset publish",
		"postrelease": "git push --follow-tags origin main"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@xsynaptic/eslint-config": "workspace:*",
		"eslint": "^10.5.0",
		"jiti": "^2.7.0",
		"knip": "^6.18.0",
		"prettier": "^3.8.4",
		"publint": "^0.3.21",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vitest": "^4.1.9"
	}
}
